# Banco de dados (produção). Se vazio em dev, usa PGlite local automaticamente.
DATABASE_URL=

# Painel do balcão
STAFF_PASSWORD=troque-esta-senha
SESSION_SECRET=gere-uma-string-aleatoria-bem-longa

# Loja (aparece no site e nas mensagens)
STORE_NAME=Primu's Bolos

# Motor de notificação: "assisted" (padrão, envio manual) ou "whatsapp_cloud"
NOTIFY_PROVIDER=assisted

# WhatsApp Cloud API — preencher só quando NOTIFY_PROVIDER=whatsapp_cloud
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE=bolo_disponivel
WHATSAPP_TEMPLATE_LANG=pt_BR
WHATSAPP_GRAPH_VERSION=v21.0
