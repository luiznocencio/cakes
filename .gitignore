# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local db (PGlite) e metadados de volume externo (macOS)
/.data/
._*

# prints-fonte das fotos (pesados; as imagens processadas ficam em public/bolos)
/fotos/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
